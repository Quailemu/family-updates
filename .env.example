SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
APP_VARIANT=public
# Allowed values: public, family, mobile, office
# Runtime now resolves by path first:
# / -> public, /family -> family, /mobile -> mobile, /office -> office
# APP_VARIANT remains fallback when path is unavailable/unmapped.
# Legacy host mapping key (kept for compatibility; runtime does not rely on it):
APP_VARIANT_BY_HOST=public.voicemailcare.com=public,family.voicemailcare.com=family,care-hub-mobile.voicemailcare.com=mobile,care-hub-office.voicemailcare.com=office
AUTH_COOKIE_SIGNING_KEY=replace_with_long_random_secret
AUTH_COOKIE_PERSISTENCE_ENABLED=0
FAMILY_SESSION_TIMEOUT_SECONDS=1800
FAMILY_APP_URL=https://family.voicemailcare.com
CARE_MOBILE_APP_URL=https://care-hub-mobile.voicemailcare.com
CARE_OFFICE_APP_URL=https://care-hub-office.voicemailcare.com
PASSWORD_RESET_REDIRECT_URL=https://family.voicemailcare.com/family/login
FAMILY_INVITE_REDIRECT_URL=https://family.voicemailcare.com/family/login
FAMILY_MAGIC_LINK_REDIRECT_URL=https://family.voicemailcare.com/family/login
CARE_MOBILE_MAGIC_LINK_REDIRECT_URL=https://care-hub-mobile.voicemailcare.com/care-hub/mobile/login
CARE_OFFICE_MAGIC_LINK_REDIRECT_URL=https://care-hub-office.voicemailcare.com/care-hub/login
OFFICE_MFA_REQUIRED=1
PUBLIC_VIDEO_OVERVIEW_URL=
# Legacy record video keys
PUBLIC_VIDEO_FAMILY_APP_WALKTHROUGH_URL=
PUBLIC_VIDEO_MOBILE_APP_WALKTHROUGH_URL=
PUBLIC_VIDEO_OFFICE_APP_WALKTHROUGH_URL=
# Legacy/alternate keys accepted by app runtime (for Render compatibility)
PUBLIC_VIDEO_FAMILY_URL=
PUBLIC_VIDEO_MOBILE_URL=
PUBLIC_VIDEO_OFFICE_URL=
# Legacy diagram video keys
PUBLIC_VIDEO_FAMILY_FLOW_WALKTHROUGH_URL=
PUBLIC_VIDEO_MOBILE_FLOW_WALKTHROUGH_URL=
PUBLIC_VIDEO_OFFICE_FLOW_WALKTHROUGH_URL=
# Preferred keys (locked spec): PUBLIC_<AUDIENCE>_<TYPE>_VIDEO_URL
PUBLIC_UNIVERSAL_DIAGRAM_VIDEO_URL=
PUBLIC_FAMILY_DIAGRAM_VIDEO_URL=
PUBLIC_MOBILE_DIAGRAM_VIDEO_URL=
PUBLIC_OFFICE_DIAGRAM_VIDEO_URL=
