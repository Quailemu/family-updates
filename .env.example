NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_key_here
APP_VARIANT=public
# Allowed values: public, family, mobile, office
# Runtime now resolves by path first:
# / -> public, /family -> family, /mobile -> mobile, /office -> office
# APP_VARIANT remains fallback when path is unavailable/unmapped.
# Legacy host mapping key (kept for compatibility; runtime does not rely on it):
APP_VARIANT_BY_HOST=familyupdates.care=public
AUTH_COOKIE_SIGNING_KEY=replace_with_long_random_secret
AUTH_COOKIE_PERSISTENCE_ENABLED=0
APP_LIVE_REFRESH=1
APP_FAMILY_LIVE_REFRESH=0
APP_MOBILE_LIVE_REFRESH=1
APP_OFFICE_LIVE_REFRESH=0
# Local-only developer shortcut for backend work. Requires SUPABASE_SECRET_KEY
# and only activates when the request host is localhost/127.0.0.1/::1.
DEV_AUTH_BYPASS=0
DEV_AUTH_BYPASS_CARE_HOME_ID=
DEV_AUTH_BYPASS_AUTH_UID=
FAMILY_SESSION_TIMEOUT_SECONDS=1800
CANONICAL_PUBLIC_HOST=familyupdates.care
CANONICAL_PUBLIC_HOST_ALIASES=www.familyupdates.care
FAMILY_APP_URL=https://familyupdates.care/family/login
CARE_MOBILE_APP_URL=https://familyupdates.care/care-hub/mobile/login
CARE_OFFICE_APP_URL=https://familyupdates.care/care-hub/login
PASSWORD_RESET_REDIRECT_URL=https://familyupdates.care/family/login
FAMILY_INVITE_REDIRECT_URL=https://familyupdates.care/family/login
FAMILY_MAGIC_LINK_REDIRECT_URL=https://familyupdates.care/family/login
CARE_MOBILE_MAGIC_LINK_REDIRECT_URL=https://familyupdates.care/care-hub/mobile/login
CARE_OFFICE_MAGIC_LINK_REDIRECT_URL=https://familyupdates.care/care-hub/login
OFFICE_MFA_REQUIRED=1
MEDIA_BASE_URL=https://media.familyupdates.care
MEDIA_BUCKET_NAME=familyupdates-media
MEDIA_TEST_VIDEO_OBJECT_PATH=video-walkthrough.mp4
FAMILY_RECORD_VIDEO_OBJECT_PATH=familyhub-walkthrough.mp4
CARE_HOME_BANNER_OBJECT_PATH=banners/office/care-home-banner.png
# Preferred keys (locked spec): PUBLIC_<AUDIENCE>_<TYPE>_VIDEO_URL
PUBLIC_UNIVERSAL_DIAGRAM_VIDEO_URL=
PUBLIC_FAMILY_RECORD_VIDEO_URL=
PUBLIC_MOBILE_RECORD_VIDEO_URL=
PUBLIC_OFFICE_RECORD_VIDEO_URL=

# Optional upload-time message transcription (stored only on current message row)
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
