SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
APP_VARIANT=public
# Allowed values: public, family, mobile, office
# Runtime now resolves by path first:
# / -> public, /family -> family, /mobile -> mobile, /office -> office
# APP_VARIANT remains fallback when path is unavailable/unmapped.
# Legacy host mapping key (kept for compatibility; runtime does not rely on it):
APP_VARIANT_BY_HOST=voicemailcare.com=public
AUTH_COOKIE_SIGNING_KEY=replace_with_long_random_secret
AUTH_COOKIE_PERSISTENCE_ENABLED=0
APP_LIVE_REFRESH=1
APP_FAMILY_LIVE_REFRESH=0
APP_MOBILE_LIVE_REFRESH=1
APP_OFFICE_LIVE_REFRESH=0
FAMILY_SESSION_TIMEOUT_SECONDS=1800
FAMILY_APP_URL=https://voicemailcare.com/family/login
CARE_MOBILE_APP_URL=https://voicemailcare.com/care-hub/mobile/login
CARE_OFFICE_APP_URL=https://voicemailcare.com/care-hub/login
PASSWORD_RESET_REDIRECT_URL=https://voicemailcare.com/family/login
FAMILY_INVITE_REDIRECT_URL=https://voicemailcare.com/family/login
FAMILY_MAGIC_LINK_REDIRECT_URL=https://voicemailcare.com/family/login
CARE_MOBILE_MAGIC_LINK_REDIRECT_URL=https://voicemailcare.com/care-hub/mobile/login
CARE_OFFICE_MAGIC_LINK_REDIRECT_URL=https://voicemailcare.com/care-hub/login
OFFICE_MFA_REQUIRED=1
MEDIA_BASE_URL=https://media.voicemailcare.com
CARE_HOME_BANNER_OBJECT_PATH=banners/office/care-home-banner.png
PUBLIC_VIDEO_OVERVIEW_URL=
# Legacy record video keys
PUBLIC_VIDEO_FAMILY_APP_WALKTHROUGH_URL=
PUBLIC_VIDEO_MOBILE_APP_WALKTHROUGH_URL=
PUBLIC_VIDEO_OFFICE_APP_WALKTHROUGH_URL=
# Legacy/alternate keys accepted by app runtime (for Render compatibility)
PUBLIC_VIDEO_FAMILY_URL=
PUBLIC_VIDEO_MOBILE_URL=
PUBLIC_VIDEO_OFFICE_URL=
# Legacy diagram video keys
PUBLIC_VIDEO_FAMILY_FLOW_WALKTHROUGH_URL=
PUBLIC_VIDEO_MOBILE_FLOW_WALKTHROUGH_URL=
PUBLIC_VIDEO_OFFICE_FLOW_WALKTHROUGH_URL=
# Preferred keys (locked spec): PUBLIC_<AUDIENCE>_<TYPE>_VIDEO_URL
PUBLIC_UNIVERSAL_DIAGRAM_VIDEO_URL=
PUBLIC_FAMILY_DIAGRAM_VIDEO_URL=
PUBLIC_MOBILE_DIAGRAM_VIDEO_URL=
PUBLIC_OFFICE_DIAGRAM_VIDEO_URL=
PUBLIC_FAMILY_RECORD_VIDEO_URL=
PUBLIC_MOBILE_RECORD_VIDEO_URL=
PUBLIC_OFFICE_RECORD_VIDEO_URL=

# Optional upload-time message transcription (stored only on current message row)
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
